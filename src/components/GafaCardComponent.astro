---
import '../styles/global.css';
import '../styles/landing-page.css';

interface Props {
    portadaImgUrl: string;
    nombreModelo: string;
    codigoColorModelo: string;
    esNovedad?: boolean;
}

const {
    portadaImgUrl,
    nombreModelo,
    codigoColorModelo,
    esNovedad = false,
} = Astro.props;
---

<article class="gafa-card-component">
    {esNovedad && <span class="new-badge">New</span>}

    <div class="gafa-card-image">
        <img src={portadaImgUrl} alt={nombreModelo} loading="lazy" />
    </div>

    <div class="gafa-card-details">
        <h3>{nombreModelo}</h3>
        <p>{codigoColorModelo}</p>
    </div>
</article>

<style>
    @font-face{
    font-family:'HkNova';
    src: url('/font/HKNova-Medium.ttf') format('truetype');
    font-display: swap;
}
    .gafa-card-component {
        position: relative;
        padding:1rem;
        box-shadow: 5px 5px 16px rgba(0, 0, 0, 0.1);
        max-width: 20vw;
        max-height: auto;
        background-color: #fbfbfb;

    }
    .gafa-card-image img {
        width: 100%;
        height: auto;
        display: block;
    }

    /*El badge de abajo es para las imagenes con la etiqueta "New" del index.*/
   .new-badge { 
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        z-index: 2;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        background: #0f0f0f;
        color: #fff;
    }

    .gafa-card-details {
        margin-top: 0.5rem;
        font-family: 'HkNova', sans-serif;
    }
</style>