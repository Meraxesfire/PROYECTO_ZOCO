---
import '../styles/global.css';
import '../styles/landing-page.css';

interface Props {
    portadaImgUrl: string;
    nombreModelo: string;
    codigoColorModelo: string;
    esNovedad?: boolean;
}

const {
    portadaImgUrl,
    nombreModelo,
    codigoColorModelo,
    esNovedad = false,
} = Astro.props;
---

<article class="gafa-card-component">
    {esNovedad && <span class="new-badge">New</span>}

    <div class="gafa-card-image">
        <img src={portadaImgUrl} alt={nombreModelo} loading="lazy" />
    </div>

    <div class="gafa-card-details">
        <h3>{nombreModelo}</h3>
        <p>{codigoColorModelo}</p>
    </div>
</article>

<style>
    @font-face{
    font-family:'HkNova';
    src: url('/font/HKNova-Medium.ttf') format('truetype');
    font-display: swap;
}
    .gafa-card-component {
        position: relative;
        padding:1rem;
        box-shadow: 5px 5px 16px rgba(0, 0, 0, 0.1);
        max-width: 20vw;
        max-height: auto;
        background-color: #fbfbfb;

    }
    .gafa-card-image img {
        width: 100%;
        height: auto;
        display: block;
    }

    /*El badge de abajo es para las imagenes con la etiqueta "New" del index.*/
   .new-badge { 
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        z-index: 2;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        background: #0f0f0f;
        color: #fff;
    }

    .gafa-card-details {
        margin-top: 0.5rem;
        font-family: 'HkNova', sans-serif;
    }

    .gafa-card-details h3 {
        margin: 0;
        font-size: clamp(0.5rem, 1.1vw, 1.25rem);
        line-height: 1.2;
    }

    .gafa-card-details p {
        margin: 0.25rem 0 0;
        font-size: clamp(0.5rem, 0.85vw, 0.98rem);
        line-height: 1.3;
    }

    /*Caso de titulos del gafacard para pantalla grande*/
    @media (min-width: 1440px) {
  .titulo {
    font-size: 2.4rem;
  }
}

    @media screen and (max-width: 768px) {
    .gafa-card-component {
        min-width: 35%;
        max-width: 35vw;
        padding: 0.9rem;
    }

    .gafa-card-details h3 {
        font-size: clamp(0.95rem, 3.8vw, 1.2rem);
    }

    .gafa-card-details p {
        font-size: clamp(0.78rem, 3.2vw, 0.98rem);
    }
}
    </style>