---
// Layout para el footer de todas las páginas

const currentYear =new Date().getFullYear();
const startYear = 2024;
const copyrightYears = startYear == currentYear ? `${currentYear}` : `${startYear}-${currentYear}`;

---
    <div class="b2b-container">
        <h1>¿Quieres formar parte de nuestra gran familia?</h1>
        <p>Si eres un <b>profesional del sector óptico</b> y quieres ofrecer a tus clientes la experiencia ZOCO®, ponte en contacto con nosotros. Estamos deseando colaborar contigo y llevar la visión de ZOCO® a más personas.</p>
        <button class="b2b-button" onclick="window.location.href='/contact'">Contact us</button>
    </div>
<footer class="footer">
    <div class="footer-bussiness-content">
        <img src="https://nnugidpnpteujhlyxjav.supabase.co/storage/v1/object/sign/LOGOS%20ZOCO/zocobgRemove.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8yMGU5OTgzYS1jNmMwLTQ1NjItYWNjNy1hMDQ5MWYyMGM5M2MiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJMT0dPUyBaT0NPL3pvY29iZ1JlbW92ZS5wbmciLCJzY29wZSI6ImRvd25sb2FkIiwiaWF0IjoxNzgzNDI5MjkyLCJleHAiOjQ5MzcwMjkyOTJ9.Nz0VT39WB7CsWMraK5Q8Q1d1tUvyIj_fL4XaMpSPxas" alt="Logo ZOCO" class="footer-logo" />
        <p class="bussines-p">&copy; {copyrightYears} ZOCO</p>
        <p class="bussines-p">All rights reserved.</p>
        <br>
        <div class="subscribe-container">
            <p>Subscribe to our newsletter</p>
            <form class="subscribe-form" action="" method="post" target="_blank" novalidate>
                <input class="input-subscribe-form" type="email" name="EMAIL" placeholder="Your email address" required>
                <button class="subscribe-form-button" type="submit">Subscribe</button>
                </form>
        </div>
    </div>
    <div class="footer-info-links">
        <p>INFO</p>
        <a href="/contact" class="footer-link">Contact</a>  
        <a href="/terms&conditions" class="footer-link">Terms & Conditions</a>
        <a href="/ShippingInfo" class="footer-link">Shipping Info</a>
        <a href="/FAQ" class="footer-link">FAQ</a>
        <a href="/Jobs" class="footer-link">Jobs</a>
        <a href="/Privacy-policy" class="footer-link">Privacy Policy</a>
        <a href="/Cookies-policy" class="footer-link">Cookies Policy</a>
    </div>
    <div class="footer-social-links">
        <p>SOCIAL</p>
        <a href="https://www.instagram.com/zocoeyewear" target="_blank" rel="noopener noreferrer" class="footer-link">
            <img class="logo-rrss" src="https://nnugidpnpteujhlyxjav.supabase.co/storage/v1/object/sign/LOGOS%20ZOCO/ig_logo.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8yMGU5OTgzYS1jNmMwLTQ1NjItYWNjNy1hMDQ5MWYyMGM5M2MiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJMT0dPUyBaT0NPL2lnX2xvZ28ucG5nIiwic2NvcGUiOiJkb3dubG9hZCIsImlhdCI6MTc4MzQyOTk2MywiZXhwIjo0OTM3MDI5OTYzfQ.ePRRsBwI2RooYNJ4qVPIKLxmGgtYjZkN59Gx6Za2dsc" alt="Instagram logo-link"/>
            Instagram</a>
        <a href="https://www.facebook.com/zocoeyewear" target="_blank" rel="noopener noreferrer" class="footer-link">
            <img class="logo-rrss" src="https://nnugidpnpteujhlyxjav.supabase.co/storage/v1/object/sign/LOGOS%20ZOCO/facebook_logo.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8yMGU5OTgzYS1jNmMwLTQ1NjItYWNjNy1hMDQ5MWYyMGM5M2MiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJMT0dPUyBaT0NPL2ZhY2Vib29rX2xvZ28ucG5nIiwic2NvcGUiOiJkb3dubG9hZCIsImlhdCI6MTc4MzQzMDAyNywiZXhwIjo0OTM3MDMwMDI3fQ.psuxv8aN13TXRiX8Tb4cyOQXrxXZVBBNoPQXQoNBphs" alt="Facebook logo-link" />
            Facebook</a>
    </div>
</footer>

<style>

    .b2b-container {
        display:block;
        position: relative;
        width: 100%;
        flex-direction: column;
        align-items: center;
        text-align: center;
        background-color: #f7f0e6;
        color:#daa431;
        font-family: 'HkNova', sans-serif;
        padding: clamp(1.9rem, 4vw, 4rem);
    }

    .b2b-container h1 {
        font-size: clamp(1.5rem, 3vw, 2.5rem);
        margin-bottom: 1rem;
    }

    .b2b-container p{
        font-size: clamp(0.4rem, 1.9vw, 1.5rem);
        max-width: 800px;
        margin: 0 auto;
        color:black;
    }

    .b2b-button {
        margin-top: 1rem;
        padding: 0.5rem 1.5rem;
        font-size: clamp(0.7rem, 1.5vw, 1.5rem);
        background-color: #303030;
        color: white;
        border: none;
        cursor: pointer;
        font-weight: bold;
        font-family: 'HkNova', sans-serif;
        transition: all 0.3s ease;
        border-radius: 4px;
    }

    .b2b-button:hover {
        background-color: #daa431;
        color: #507c79;
        font-weight: bold;
        font-family: 'HkNova', sans-serif;
        transition: all 0.3s ease;
    }
    .footer {
        background-color: #70c2a5;
        width: 100%;
        min-height: 19rem;
        display: grid;
        grid-template-columns: minmax(18rem, 0.6fr) auto auto;
        column-gap: clamp(2rem, 6vw, 6rem);
        row-gap: 1.25rem;
        align-items: flex-start;
        padding: 35px clamp(1.25rem, 3vw, 30px);
        text-align: center;
        font-family: 'HkNova', sans-serif;
        padding-bottom:2rem;
    }
    
    .footer-link{
        font-size: clamp(0.7rem, 1.5vw, 1.5rem);
    }

    .footer-bussiness-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: left;
        margin-left: 30px;
    }
    .bussines-p{
        font-size: clamp(0.7rem, 0.85vw, 0.85rem);
        color: rgb(0, 0, 0);}

    .footer-logo {
        width: 90px;
        height: auto;
        max-width: 200px;
        margin-bottom: 10px;
    }

    .subscribe-container p{
        color: rgb(55, 127, 127);   
        font-size: clamp(0.5rem, 2.2vw, 1.5rem);
    }

    .subscribe-form{
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 10px;
    }

    .input-subscribe-form {
        padding: 0.5rem;
        border: none;
        width: min(100%, 15rem);
        margin-right: 0;
        background: transparent;
        border-bottom: 1px solid #303030;
    }
    .input-subscribe-form::placeholder {
        color: rgb(57, 125, 125);
    }

    .input-subscribe-form:focus {
        outline: none;
        border-bottom: 1px solid #303030;
    }

    .subscribe-form-button{
        font-family: 'HkNova', sans-serif;
        padding: 0.2rem 1rem;
        background-color: #4c4b4b3c;
        color: #fff;
        border: none;
        cursor: pointer;
    }

    .footer-info-links, .footer-social-links {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        margin-left: 0;
    }

    .footer-info-links p, .footer-social-links p {
        font-weight: bold;
        margin-bottom: 10px;
        color:rgb(55, 127, 127);
    }

    .footer-info-links a, .footer-social-links a {
        color: rgb(226, 226, 226);
        text-decoration: none;
        margin-bottom: 5px;
    }

    .footer-info-links a:hover, .footer-social-links a:hover {
        text-decoration: underline;
    }

    .logo-rrss {
        width: 20px;
        height: auto;
        margin-right: 5px;
    }

    @media (max-width: 900px) {
        .footer {
            grid-template-columns: 1fr 1fr;
            column-gap: 2rem;
            row-gap: 1.5rem;
            min-height: auto;
        }

        .footer-bussiness-content {
            grid-column: 1 / -1;
            margin-left: 0;
        }
    }

    @media (max-width: 640px) {
        .footer {
            grid-template-columns: 1fr;
            row-gap: 1.25rem;
            padding: 1.5rem 1rem 2rem;
            text-align: left;
        }

        .footer-bussiness-content,
        .footer-info-links,
        .footer-social-links {
            margin-left: 0;
            align-items: flex-start;
        }

        .footer-logo {
            width: clamp(70px, 22vw, 90px);
        }

        .subscribe-form-button {
            width: auto;
        }


        .b2b-container p{
            font-size: clamp(0.9rem, 2.5vw, 1.5rem);
        }
    }




</style>