---
// src/pages/gafas/[id].astro
//Para que Vercel haga ISR real en tu [id].astro, el código en el servidor se configura así:
import { getGafaPorId } from '../../services/gafas';

const { id } = Astro.params;
const gafa = await getGafaPorId(id);

if (!gafa) return Astro.redirect('/404');

// ESTO ES EL TRUCO DEL ISR EN VERCEL:
// swr: guarda en caché de Vercel. maxage: expira en 60 segundos si entra alguien nuevo.
Astro.response.headers.set(
  'Cache-Control',
  's-maxage=60, stale-while-revalidate=31536000'
);
--- 