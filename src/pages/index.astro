---
import Layout from '../layouts/LayoutLandingPage.astro';
import GafaCardComponent from '../components/GafaCardComponent.astro';
import FooterComponent from '../components/FooterPages.astro';
import { supabase } from '../lib/supabase';

import '../styles/global.css';
import '../styles/landing-page.css';

// Para que Vercel haga ISR real en tu index.astro, el código en el servidor se configura así:
// ESTE EXPORT ES EL TRUCO DEL ISR EN VERCEL:
export const prerender=true;
   
//constante de título de la página, previsamente declarada en el layout de la landing page, para que se muestre en el title del head.
const pageTitle = 'Inicio';

//--------------------------------------------------------------------------------------------------

// Query para sacar best sellers con foto de portada disponible.
const { data: bestSellers, error: bestSellersError } = await supabase
	.from('gafas_con_portada')
	.select('*')
	.eq('best_seller', true)
	.not('portada_img_url', 'is', null)
	.limit(4);

// Query para sacar las 2 fotos de portada de las nuevas gafas SUN y OPTICAL, para mostrarlas en la sección de New Arrivals.
const { data: newArrivalsSun, error: newArrivalsSunError } = await supabase
	.from('new_arrivals_photos')
	.select('foto_modelo, foto_hover')
	.ilike('tipo', 'SUN')
	.not('foto_modelo', 'is', null)
	.limit(1);

	//query para gafa optical de new arrival
const { data: newArrivalsOptical, error: newArrivalsOpticalError } = await supabase
	.from('new_arrivals_photos')
	.select('foto_modelo, foto_hover')
	.ilike('tipo', 'OPTICAL')
	.not('foto_modelo', 'is', null)
		.limit(1);



//Queries para carrousel de gafas de NEW ARRIVALS, que se muestran en la sección de New Arrivals, y que vienen de la tabla gafas_con_portada, filtradas por es_novedad = true y con foto de portada disponible.
const { data: newArrivalsCarrousel, error: newArrivalsCarrouselError } = await supabase
	.from('gafas_con_portada')
	.select('*')
	.not('portada_img_url', 'is', null)
	.order('id', { ascending: false })
	.limit(10);

const newArrivalsCarrouselItems = (newArrivalsCarrousel ?? []).filter((gafa) => {
	if (gafa.es_novedad === true || gafa.es_novedad === 1) return true;
	if (typeof gafa.es_novedad === 'string') {
		const value = gafa.es_novedad.trim().toLowerCase();
		return value === 'true' || value === 't' || value === '1';
	}
	return false;
});


//Querie para sacar los videos de las colecciones de la landing page, que vienen de la tabla videos_colecciones_landing	, filtradas por tipo de colección y con video disponible.
	const {data: videosColecciones, error: videosColeccionesError } = await supabase
	.from('videos_colecciones_landing')
	.select('id, media_url, nombre_coleccion')
	.in('id', [1,2]);

	if (videosColeccionesError) {
		console.error('videosColecciones query failed:', videosColeccionesError.message);
	}
		//Constantes para almacenar cada uno de los videos de las colecciones, para poder mostrarlos en la landing page.
	const videoColeccion1 = videosColecciones?.find((video) => video.id === 1) ?? null;
	const videoColeccion2 = videosColecciones?.find((video) => video.id === 2) ?? null;

//Querie para el enlace que tiene el boton "mostrar más" sobre los videos de colecciones, que llevan al catalogo con un filtro por nombre de colcción ya aplicado por defecto
//Debe abrir automaticamente el catalogo con el filtro de esa colección aplicado.


//seguridad de queries
if (bestSellersError) console.error('bestSellers query failed:', bestSellersError.message);
if (newArrivalsSunError) console.error('newArrivalsSun query failed:', newArrivalsSunError.message);
if (newArrivalsOpticalError) console.error('newArrivalsOptical query failed:', newArrivalsOpticalError.message);
if (newArrivalsCarrouselError) console.error('newArrivalsCarrousel query failed:', newArrivalsCarrouselError.message);
---

	<Layout title={pageTitle}>
	<!-- <h1>Landing Page</h1>
	<p>Gafas cargadas, auditoria de conexión realizada:
		<!--slice recorre las 3 primera filas de la tabla y luego .map((gafa) => gafa.nombre_modelo).join(', ') las une a traves de una coma para motrarlas en una misma fila
		De momento tenemos el modelo {data?.slice(0,3).map((gafa) => gafa.nombre_modelo).join(', ')} en la primera, segunda y tercera fila fila</p>
		<!--Para mostrarlas de forma independiente en un P cada una: 
		{data?.slice(0, 3).map((gafa) => <p>{gafa.nombre_modelo}</p>)}-->

		<div class="texto-promo-landing">
			<!--<img src="https://nnugidpnpteujhlyxjav.supabase.co/storage/v1/object/public/ZOCO%20MEDIA/fondo-colores%20(1).png" alt="Fondo de colores de Zoco eyewear" class="fondo-colores" />-->
			<h3>Formas únicas. Color esencial. Diseñadas para llevar.</h3>
			<p>"ZOCO Captura la esencia y la luz de Andalucía en diseños que combinan la audacia de la originalidad con una versatilidad absoluta. Piezas exclusivas, cómodas y sin complicaciones, creadas para destacar en el día a día."</p>
		</div>
	
		<div class="best-sellers-section">
		<div class="titulos-best-sellers">
		<h2 class="titulo-seccion">Best Sellers</h2>
		<h4>Descubre nuestros modelos más vendidos</h4>
		</div>
		<div class="best-sellers-grid">
			{bestSellers?.map((gafa) => (
				<GafaCardComponent
					portadaImgUrl={gafa.portada_img_url}
					nombreModelo={gafa.nombre_modelo}
					codigoColorModelo={gafa.color ?? gafa.color_montura ?? gafa.codigo_color_modelo ?? 'Sin color'}
					esNovedad={gafa.es_novedad}
				/>
			))}
		</div>
	</div>



<!-- Seccion new arrivals, viene de las queries de la tabla new_arrivals_photos-->
	<div class="new-arrivals-section">
		<h2 class="titulo-seccion">New Arrivals</h2>
		<div class="new-arrivals-grid">
			<a class="featured-card" href="#" aria-label="Nueva gafa SUN">
				{newArrivalsSun?.[0]?.foto_modelo ? (
					<>
						<img class="img-base" src={newArrivalsSun[0].foto_modelo} alt="Nueva gafa SUN" />
						{newArrivalsSun?.[0]?.foto_hover && (
						<img class="img-hover" src={newArrivalsSun[0].foto_hover} alt="Nueva gafa SUN hover" />
						)}
					</>
				) : (
					<p>Imagen SUN no disponible</p>
				)}
			</a>
			<a class="featured-card" href="#" aria-label="Nueva gafa OPTICAL">
				{newArrivalsOptical?.[0]?.foto_modelo ? (
					<>
						<img class="img-base" src={newArrivalsOptical[0].foto_modelo} alt="Nueva gafa OPTICAL" />
						{newArrivalsOptical?.[0]?.foto_hover && (
						<img class="img-hover" src={newArrivalsOptical[0].foto_hover} alt="Nueva gafa OPTICAL hover" />
						)}
					</>
				) : (
					<p>Imagen OPTICAL no disponible</p>
				)}
			</a>
		</div>
		<div class="new-arrivals-carrousel">
			{newArrivalsCarrouselItems.map((gafa) => (
				<GafaCardComponent
					portadaImgUrl={gafa.portada_img_url}
					nombreModelo={gafa.nombre_modelo}
					codigoColorModelo={gafa.color ?? gafa.color_montura ?? gafa.codigo_color_modelo ?? 'Sin color'}
					esNovedad={gafa.es_novedad}
				/>
			))}
		</div>
	</div>

	<!--Sección texto info de Zoco -->

	
	<!-- Seccion de colecciones-->
	<div class="coleccion-1-container">
		{videoColeccion1?.media_url ? (
			<video class="video-coleccion" autoplay muted loop playsinline>
				<source src={videoColeccion1.media_url} type="video/mp4" />
			</video>
		) : (
			<p>Video colección 1 no disponible.</p>
		)}
		<button class="boton-mostrar-mas" onclick="window.location.href='/catalogo?coleccion=coleccion1'">Show more</button>
	</div>
	<div class="coleccion-2-container">
		{videoColeccion2?.media_url ? (
			<video class="video-coleccion" autoplay muted loop playsinline>
				<source src={videoColeccion2.media_url} type="video/mp4" />
			</video>
		) : (
			<p>Video colección 2 no disponible.</p>
		)}
		<button class="boton-mostrar-mas" onclick="window.location.href='/catalogo?coleccion=coleccion2'">Show more</button>
	</div>

	<section style="max-width: 1200px; margin: 3rem auto; padding: 0 1rem;">
		<h2 class="titulo-seccion">Prueba Gafa Card</h2>
		<GafaCardComponent
			portadaImgUrl="https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&w=900&q=80"
			nombreModelo="Gafa test"
			codigoColorModelo="C1 - Black"
			esNovedad={true}
		/>
	</section>

	<!-- Seccion de footer, componente footerPages.astro-->
	<footer>
		<FooterComponent />
	</footer>


	


	</Layout>
