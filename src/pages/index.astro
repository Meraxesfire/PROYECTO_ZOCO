---
import Layout from '../layouts/LayoutLandingPage.astro';
import GafaCardComponent from '../components/GafaCardComponent.astro';
import FooterComponent from '../components/FooterPages.astro';
import { supabase } from '../lib/supabase';

import '../styles/global.css';
import '../styles/landing-page.css';
   
//constante de título de la página, previsamente declarada en el layout de la landing page, para que se muestre en el title del head.
const pageTitle = 'Inicio';

//--------------------------------------------------------------------------------------------------

// Query para sacar best sellers con foto de portada disponible.
const { data: bestSellers, error: bestSellersError } = await supabase
	.from('gafas_con_portada')
	.select('*')
	.eq('best_seller', true)
	.not('portada_img_url', 'is', null)
	.limit(4);

// Query para sacar las 2 fotos de portada de las nuevas gafas SUN y OPTICAL, para mostrarlas en la sección de New Arrivals.
const { data: newArrivalsSun, error: newArrivalsSunError } = await supabase
	.from('new_arrivals_photos')
	.select('foto_modelo, foto_hover')
	.ilike('tipo', 'SUN')
	.not('foto_modelo', 'is', null)
	.limit(1);

	//query para gafa optical de new arrival
const { data: newArrivalsOptical, error: newArrivalsOpticalError } = await supabase
	.from('new_arrivals_photos')
	.select('foto_modelo, foto_hover')
	.ilike('tipo', 'OPTICAL')
	.not('foto_modelo', 'is', null)
		.limit(1);



//Queries para carrousel de gafas de NEW ARRIVALS, que se muestran en la sección de New Arrivals, y que vienen de la tabla gafas_con_portada, filtradas por es_novedad = true y con foto de portada disponible.
const { data: newArrivalsCarrousel, error: newArrivalsCarrouselError } = await supabase
	.from('gafas_con_portada')
	.select('*')
	.not('portada_img_url', 'is', null)
	.order('id', { ascending: false })
	.limit(10);

const newArrivalsCarrouselItems = (newArrivalsCarrousel ?? []).filter((gafa) => {
	if (gafa.es_novedad === true || gafa.es_novedad === 1) return true;
	if (typeof gafa.es_novedad === 'string') {
		const value = gafa.es_novedad.trim().toLowerCase();
		return value === 'true' || value === 't' || value === '1';
	}
	return false;
});


//Querie para sacar los videos de las colecciones de la landing page, que vienen de la tabla videos_colecciones_landing	, filtradas por tipo de colección y con video disponible.
	const {data: videosColecciones, error: videosColeccionesError } = await supabase
	.from('videos_colecciones_landing')
	.select('id, media_url, nombre_coleccion')
	.in('id', [1,2]);

	if (videosColeccionesError) {
		console.error('videosColecciones query failed:', videosColeccionesError.message);
	}
		//Constantes para almacenar cada uno de los videos de las colecciones, para poder mostrarlos en la landing page.
	const videoColeccion1 = videosColecciones?.find((video) => video.id === 1) ?? null;
	const videoColeccion2 = videosColecciones?.find((video) => video.id === 2) ?? null;

//Querie para el enlace que tiene el boton "mostrar más" sobre los videos de colecciones, que llevan al catalogo con un filtro por nombre de colcción ya aplicado por defecto
//Debe abrir automaticamente el catalogo con el filtro de esa colección aplicado.


//seguridad de queries
if (bestSellersError) console.error('bestSellers query failed:', bestSellersError.message);
if (newArrivalsSunError) console.error('newArrivalsSun query failed:', newArrivalsSunError.message);
if (newArrivalsOpticalError) console.error('newArrivalsOptical query failed:', newArrivalsOpticalError.message);
if (newArrivalsCarrouselError) console.error('newArrivalsCarrousel query failed:', newArrivalsCarrouselError.message);
---

	<Layout title={pageTitle}>
	<!-- <h1>Landing Page</h1>
	<p>Gafas cargadas, auditoria de conexión realizada:
		<!--slice recorre las 3 primera filas de la tabla y luego .map((gafa) => gafa.nombre_modelo).join(', ') las une a traves de una coma para motrarlas en una misma fila
		De momento tenemos el modelo {data?.slice(0,3).map((gafa) => gafa.nombre_modelo).join(', ')} en la primera, segunda y tercera fila fila</p>
		<!--Para mostrarlas de forma independiente en un P cada una: 
		{data?.slice(0, 3).map((gafa) => <p>{gafa.nombre_modelo}</p>)}-->
	
		<div class="best-sellers-section">
		<div class="titulos-best-sellers">
		<h2 class="titulo-seccion">Best Sellers</h2>
		<h4>Descubre nuestros modelos más vendidos</h4>
		</div>
		<div class="best-sellers-grid">
			{bestSellers?.map((gafa) => (
				<GafaCardComponent
					portadaImgUrl={gafa.portada_img_url}
					nombreModelo={gafa.nombre_modelo}
					codigoColorModelo={gafa.color ?? gafa.color_montura ?? gafa.codigo_color_modelo ?? 'Sin color'}
					esNovedad={gafa.es_novedad}
				/>
			))}
		</div>
	</div>
 
	<section class="pin-section" id="pinSection">
		<div class="pin-inner" id="pinInner">
			<h3>DICEN DE ZOCO</h3>
			<p id="aboutText">«ZOCO está marcada por un <b data-kw class="palabra-color1">diseño singular</b>,  <b data-kw class="palabra-color2">oficio óptico</b> y  <b data-kw class="palabra-color3">espíritu familiar</b>. <br>Formas propias y atemporales, con combinaciones cromaticas cuidadosamente equilibradas.»</p>
			<p class="firma-comentario"><i>-LookVision 2026</i></p>
		</div>
	</section>

<!-- Seccion new arrivals, viene de las queries de la tabla new_arrivals_photos-->
	<div class="new-arrivals-section">
		<h2 class="titulo-seccion">New Arrivals</h2>
		<div class="new-arrivals-grid">
			<a class="featured-card" href="#" aria-label="Nueva gafa SUN">
				{newArrivalsSun?.[0]?.foto_modelo ? (
					<>
						<img class="img-base" src={newArrivalsSun[0].foto_modelo} alt="Nueva gafa SUN" />
						{newArrivalsSun?.[0]?.foto_hover && (
						<img class="img-hover" src={newArrivalsSun[0].foto_hover} alt="Nueva gafa SUN hover" />
						)}
					</>
				) : (
					<p>Imagen SUN no disponible</p>
				)}
			</a>
			<a class="featured-card" href="#" aria-label="Nueva gafa OPTICAL">
				{newArrivalsOptical?.[0]?.foto_modelo ? (
					<>
						<img class="img-base" src={newArrivalsOptical[0].foto_modelo} alt="Nueva gafa OPTICAL" />
						{newArrivalsOptical?.[0]?.foto_hover && (
						<img class="img-hover" src={newArrivalsOptical[0].foto_hover} alt="Nueva gafa OPTICAL hover" />
						)}
					</>
				) : (
					<p>Imagen OPTICAL no disponible</p>
				)}
			</a>
		</div>
		<div class="new-arrivals-carrousel">
			{newArrivalsCarrouselItems.map((gafa) => (
				<GafaCardComponent
					portadaImgUrl={gafa.portada_img_url}
					nombreModelo={gafa.nombre_modelo}
					codigoColorModelo={gafa.color ?? gafa.color_montura ?? gafa.codigo_color_modelo ?? 'Sin color'}
					esNovedad={gafa.es_novedad}
				/>
			))}
		</div>
	</div>

	<!--Sección texto info de Zoco -->

	
	<!-- Seccion de colecciones-->
	<div class="coleccion-1-container">
		{videoColeccion1?.media_url ? (
			<video class="video-coleccion" autoplay muted loop playsinline>
				<source src={videoColeccion1.media_url} type="video/mp4" />
			</video>
		) : (
			<p>Video colección 1 no disponible.</p>
		)}
		<button class="boton-mostrar-mas" onclick="window.location.href='/catalogo?coleccion=coleccion1'">Show more</button>
	</div>
	<div class="coleccion-2-container">
		{videoColeccion2?.media_url ? (
			<video class="video-coleccion" autoplay muted loop playsinline>
				<source src={videoColeccion2.media_url} type="video/mp4" />
			</video>
		) : (
			<p>Video colección 2 no disponible.</p>
		)}
		<button class="boton-mostrar-mas" onclick="window.location.href='/catalogo?coleccion=coleccion2'">Show more</button>
	</div>

	<!--<section style="max-width: 1200px; margin: 3rem auto; padding: 0 1rem;">
		<h2 class="titulo-seccion">Prueba Gafa Card</h2>
		<GafaCardComponent
			portadaImgUrl="https://images.unsplash.com/photo-1511499767150-a48a237f0083?auto=format&fit=crop&w=900&q=80"
			nombreModelo="Gafa test"
			codigoColorModelo="C1 - Black"
			esNovedad={true}
		/>
	</section> -->

	<!-- Seccion de footer, componente footerPages.astro-->
	<footer>
		<FooterComponent />
	</footer>


	


	<Fragment slot="page-scripts">
	<script is:inline>
	(function(){
	  // Elementos principales del bloque con efecto scroll
	  const pinSection = document.getElementById('pinSection');
	  const pinInner   = document.getElementById('pinInner');
	  const aboutText  = document.getElementById('aboutText');
	  if(!pinSection || !pinInner || !aboutText) return;

	  // Divide el texto en palabras normales y palabras destacadas data-kw
	  function buildWords(){
	    const nodes = Array.from(aboutText.childNodes);
	    aboutText.innerHTML = '';
	    let wordIndex = 0;
	    const kwEls = [];
	    const normalEls = [];

	    nodes.forEach(node => {
	      if(node.nodeType === Node.TEXT_NODE){
	        node.textContent.split(/(\s+)/).forEach(chunk => {
	          if(chunk.trim() === '') { aboutText.appendChild(document.createTextNode(chunk)); return; }
	          const span = document.createElement('span');
	          span.className = 'word';
	          span.textContent = chunk;
	          span.dataset.index = wordIndex++;
	          aboutText.appendChild(span);
	          normalEls.push(span);
	        });
	      } else if(node.nodeType === Node.ELEMENT_NODE && node.hasAttribute('data-kw')){
	        const spacer = document.createElement('span');
	        spacer.className = 'kw-spacer word';
	        spacer.textContent = node.textContent;
	        spacer.dataset.index = wordIndex++;
	        aboutText.appendChild(spacer);

	        const kw = document.createElement('span');
	        kw.className = 'kw ' + node.className;
	        kw.textContent = node.textContent;
	        pinInner.appendChild(kw);

	        kwEls.push({ el: kw, spacer });
	      } else if(node.nodeType === Node.ELEMENT_NODE && node.tagName === 'BR'){
	        aboutText.appendChild(document.createElement('br'));
	      }
	    });
	    return { normalEls, kwEls };
	  }

	  // Generador simple para introducir variacion visual en las palabras normales
	  function rand(seed){
	    const x = Math.sin(seed * 999) * 10000;
	    return x - Math.floor(x);
	  }

	  // Utilidades de animacion: acotado y interpolacion lineal
	  const clamp = (v, min, max) => Math.min(max, Math.max(min, v));
	  const lerp  = (a, b, t) => a + (b - a) * t;

	  // Espera a que la fuente cargue antes de medir y animar texto
	  document.fonts.ready.then(() => {
	    requestAnimationFrame(() => {
	      const { normalEls, kwEls } = buildWords();

	      // Estado medido del layout para reposicionar las palabras destacadas
	      let initialRects = [];
	      let targetCenters = [];
	      let pinDims = { width: 0, height: 0 };

	      // Mide el texto base y calcula la posicion final de las data-kw
	      function measure(){
	        const pinRect = pinInner.getBoundingClientRect();
	        pinDims = { width: pinRect.width, height: pinRect.height };

	        initialRects = kwEls.map(({ spacer }) => {
	          const r = spacer.getBoundingClientRect();
	          const styles = window.getComputedStyle(spacer);
	          const baseFontSize = parseFloat(styles.fontSize);
	          const baseLineHeight = Number.isFinite(parseFloat(styles.lineHeight))
	            ? parseFloat(styles.lineHeight)
	            : baseFontSize * 1.5;
	          return {
	            left: r.left - pinRect.left,
	            top: r.top - pinRect.top,
	            width: r.width,
	            height: r.height,
	            centerX: r.left - pinRect.left + r.width / 2,
	            centerY: r.top - pinRect.top + r.height / 2,
	            baseFontSize,
	            baseLineHeight
	          };
	        });

	        kwEls.forEach(({ el }, i) => {
	          const r = initialRects[i];
	          el.style.left = r.centerX + 'px';
	          el.style.top = r.centerY + 'px';
	          el.style.fontSize = r.baseFontSize + 'px';
	          el.style.lineHeight = r.baseLineHeight + 'px';
	        });

	        const centerX = pinRect.width / 2;
	        const centerY = pinRect.height / 2;
	        const maxSpacerHeight = Math.max(...kwEls.map(({ spacer }) => spacer.getBoundingClientRect().height));
	        const gap = window.innerWidth < 768 ? maxSpacerHeight + 20 : 78;
	        const n = kwEls.length;

	        targetCenters = kwEls.map((_, i) => ({
	          x: centerX,
	          y: centerY + (i - (n - 1) / 2) * gap
	        }));
	      }

	      // Primera medicion y recalculo cuando cambia el viewport
	      measure();
	      window.addEventListener('resize', measure);

	      // Actualiza la animacion en funcion del scroll actual
	      function update(){
	        const rect = pinSection.getBoundingClientRect();
	        const total = pinSection.offsetHeight - window.innerHeight;
	        const scrolled = -rect.top;
	        const progress = clamp(total > 0 ? scrolled / total : 0, 0, 1);

			//AJUSTAR AQUI EL TIMING DEL SCROLL PARA QUE LAS PALABRAS SE MUEVAN Y CREZCAN A LA VELOCIDAD QUE QUERAMOS
	        // Tramos de scroll: movimiento de keywords, desvanecido de texto normal y crecimiento final
	        const animationEnd = 0.80;
	        const t1 = clamp((progress - 0.20) / (animationEnd - 0.20), 0, 1);
	        const t1words = clamp((progress - 0.20) / 0.40, 0, 1);
	        const t2 = clamp((progress - 0.64) / (animationEnd - 0.64), 0, 1);

	        // Letras normales: se dispersan y desaparecen progresivamente
	        const nTotal = normalEls.length || 1;
	        normalEls.forEach((el, i) => {
	          const stagger = i / nTotal;
	          const local = clamp((t1words - stagger * 0.5) / (1 - stagger * 0.5), 0, 1);
	          const seed = Number(el.dataset.index) + 1;
	          const dx = (rand(seed) - 0.5) * 260 * local;
	          const dy = -120 * local - rand(seed * 2) * 60 * local;
	          const rot = (rand(seed * 3) - 0.5) * 40 * local;
	          el.style.opacity = 1 - local;
	          el.style.transform = 'translate(' + dx + 'px, ' + dy + 'px) rotate(' + rot + 'deg)';
	        });

	        // Palabras data-kw: se desplazan al centro, crecen y en mobile separan mas sus lineas
	        const growth = 1 + t2 * 2;
	        const isMobile = window.innerWidth < 768;
	        const maxBaseLineH = Math.max(...initialRects.map(r => r.baseLineHeight));
	        const dynGap = isMobile ? maxBaseLineH * growth + 48 : 78;
	        const nKw = kwEls.length;
	        const h3Title = pinInner.querySelector('h3');
	        const firmaComentario = pinInner.querySelector('.firma-comentario');
	        const tH3 = isMobile ? clamp((progress - 0.40) / 0.20, 0, 1) : 0;

	        // Reposicion y escalado de cada keyword destacada
	        kwEls.forEach(({ el }, i) => {
	          const start = initialRects[i];
	          const dynTargetX = pinDims.width / 2;
	          const dynTargetY = pinDims.height / 2 + (i - (nKw - 1) / 2) * dynGap;
	          const curCenterX = lerp(start.centerX, dynTargetX, t1);
	          const curCenterY = lerp(start.centerY, dynTargetY, t1);
	          const dx = Math.round(curCenterX - start.centerX);
	          const dy = Math.round(curCenterY - start.centerY);
	          el.style.transform = 'translate(-50%, -50%) translate(' + dx + 'px, ' + dy + 'px)';
	          el.style.fontSize = start.baseFontSize * growth + 'px';
	          el.style.lineHeight = start.baseLineHeight * growth + 'px';
	          el.style.opacity = 1;
	        });

	        // Fade solo en mobile para el titulo y la firma
	        if (h3Title) {
	          h3Title.style.opacity = isMobile ? String(1 - tH3) : '1';
	        }

	        if (firmaComentario) {
	          firmaComentario.style.opacity = isMobile ? String(1 - tH3) : '1';
	        }
	      }

	      // Throttle del scroll con requestAnimationFrame
	      let ticking = false;
	      function onScroll(){
	        if(!ticking){
	          requestAnimationFrame(() => { update(); ticking = false; });
	          ticking = true;
	        }
	      }

	      window.addEventListener('scroll', onScroll, { passive: true });
	      update();
	    });
	  });
	})();
	</script>
	</Fragment>

	</Layout>
