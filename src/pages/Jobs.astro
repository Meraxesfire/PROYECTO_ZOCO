---
import '../styles/global.css';
import HeaderFooterLinks from '../components/HeaderFooterLinks.astro';
import FooterPages from '../components/FooterPages.astro';
import LayoutFooterLinkPages from '../layouts/layoutFooterLinkPages.astro';

const pagetitle = 'Únete a Zoco';
// Para que Vercel haga ISR real en tu index.astro, el código en el servidor se configura así:
// ESTE EXPORT ES EL TRUCO DEL ISR EN VERCEL:
export const prerender=true;
---

<LayoutFooterLinkPages title={pagetitle}>
<HeaderFooterLinks pagetitle={pagetitle} />
<br>
<div class="jobs-container">
  <div class="jobs-text">
    <h1 class="titulo-1">Únete a Zoco®</h1>
    <br>
    <p>ZOCO® también es talento. Un equipo joven y creativo que comparte el amor por el arte, se emociona con el trabajo bien hecho y siempre quiere ir más allá.</p>
    <br>
    <p>¿Tú también tienes carácter ZOCO®? ¡Queremos conocerte!</p>
    <br>
    <br>
    <details class="accordion-section">
      <summary class="parrafo-1">Ofertas disponibles</summary>
      <div class="accordion-content">
        <p>Si estás interesado en formar parte del equipo profesional de Zoco® escríbenos a profesional@zocoeyewear.com</p>
      </div>
    </details>
  </div>
  <div class="jobs-image">
    <img src="/ZOCO_OFFICE.png" alt="Únete a Zoco" />
  </div>
</div>

<FooterPages />
</LayoutFooterLinkPages>


