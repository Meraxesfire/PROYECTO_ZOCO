---
import LayoutCatalog from '../layouts/LayoutCatalog.astro';
import FooterPages from '../components/FooterPages.astro';
import { supabase } from '../lib/supabase';
import '../styles/global.css';


const pageTitle = 'Optical'; //constante de título de la página, previamente declarada en el layout de LayoutCatalog.astro, para que se muestre en el title del header.
const title = 'Optical'; //constante de título de la página, previamente declarada en el layout de LayoutCatalog.astro, para que se muestre en el title del head.
const catalogType = 'OPTICAL'; //constante de tipo de catálogo, para que se muestre en el layout de LayoutCatalog.astro, y se pueda filtrar por tipo de catálogo en la base de datos.
const mediaSrc = 'https://nnugidpnpteujhlyxjav.supabase.co/storage/v1/object/public/ZOCO%20MEDIA/optical-header-media.mp4'; //constante de ruta de la imagen de cabecera, para que se muestre en el layout de LayoutCatalog.astro.
---



<LayoutCatalog title={title} pageTitle={pageTitle} catalogType={catalogType} mediaSrc={mediaSrc}>



	<FooterPages />

</LayoutCatalog>
