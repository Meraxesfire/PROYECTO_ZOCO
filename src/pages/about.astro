      <div class="arrow arrow-right" id="arrow-right">&#8594;</div>
    </main>

    <FooterPages />

    <!-- ============================================
         SCRIPT: Carrusel horizontal con scroll
         Desktop: rueda del ratón (wheel event)
         Mobile: swipe táctil (touch events)
         Al llegar al final/inicio, el scroll vertical
         se reanuda automáticamente.
         ============================================ -->
    <script is:inline>
    (function () {
      // Referencias al contenedor (slider) y a la pista que se mueve (track)
      var slider = document.getElementById('slider');
      var track  = document.getElementById('track');
      var arrowLeft  = document.getElementById('arrow-left');
      var arrowRight = document.getElementById('arrow-right');
      if (!slider || !track) return;

      // Número total de slides y último índice válido
      var slides = track.children.length;
      var maxIndex = slides - 1;

      // currentIndex: slide objetivo (0, 1, 2...)
      // currentX: posición actual en % (puede ser decimal durante la animación)
      // startX / targetX: origen y destino de la animación actual
      // startTime: momento en que empezó la animación
      // rafId: ID del requestAnimationFrame activo
      // isMoving: true mientras hay una animación en curso (bloquea nuevos inputs)
      var currentIndex = 0;
      var currentX = 0;
      var startX = 0;
      var targetX = 0;
      var startTime = 0;
      var rafId = null;
      var isMoving = false;

      // Variables para touch (mobile)
      var touchStartX = 0;
      var touchStartY = 0;
      var swiped = false; // evita disparar múltiples veces en un mismo gesto

      // Duración de cada transición en ms (más alto = más lento/suave)
      var DURATION = 2000;

      // Función de easing: acelera al inicio, desacelera al final
      function easeInOutCubic(t) {
        return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
      }

      // Bucle de animación: se ejecuta cada frame hasta completar DURATION
      function animate(now) {
        // t = progreso de 0 a 1
        var t = Math.min(1, (now - startTime) / DURATION);
        // Aplicar easing al progreso para suavizar
        var eased = easeInOutCubic(t);
        // Interpolar entre posición origen y destino
        currentX = startX + (targetX - startX) * eased;
        // Mover el track con translateX (GPU, sin repaints pesados)
        track.style.transform = 'translateX(' + currentX + '%)';

        if (t < 1) {
          // Todavía no terminó, pedir siguiente frame
          rafId = requestAnimationFrame(animate);
        } else {
          // Animación completada, permitir nuevos inputs
          isMoving = false;
          rafId = null;
        }
      }

      // Mover a un slide específico (index)
      function goTo(index) {
        // Limitar al rango válido
        currentIndex = Math.max(0, Math.min(maxIndex, index));
        // La animación arranca desde donde esté visualmente
        startX = currentX;
        // Cada slide ocupa 100% del ancho del slider
        targetX = -currentIndex * 100;
        startTime = performance.now();
        isMoving = true;

        // Actualizar visibilidad de flechas
        updateArrows();

        // Cancelar animación anterior si hubiera
        if (rafId) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(animate);
      }

      // Actualizar flechas: ocultar izquierda en primer slide, derecha en último
      function updateArrows() {
        if (arrowLeft)  arrowLeft.classList.toggle('arrow-hidden', currentIndex === 0);
        if (arrowRight) arrowRight.classList.toggle('arrow-hidden', currentIndex === maxIndex);
      }

      // --- DESKTOP: wheel event ---
      // Listener del wheel: convierte scroll vertical en movimiento horizontal
      slider.addEventListener('wheel', function (e) {
        var scrollingDown = e.deltaY > 0;
        var scrollingUp   = e.deltaY < 0;

        var atEnd   = currentIndex === maxIndex;
        var atStart = currentIndex === 0;

        // Si estamos en el límite en esa dirección, NO interceptar:
        // dejar que el navegador haga scroll vertical normal
        if ((scrollingDown && atEnd) || (scrollingUp && atStart)) return;

        // Bloquear el scroll vertical y mover el carrusel
        e.preventDefault();
        // Ignorar input si ya hay una animación en curso
        if (isMoving) return;

        goTo(currentIndex + (scrollingDown ? 1 : -1));
      }, { passive: false });

      // --- MOBILE: touch events (swipe) ---
      // Al tocar, guardamos la posición inicial del dedo
      slider.addEventListener('touchstart', function (e) {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        swiped = false;
      }, { passive: true });

      // Durante el movimiento, prevenir scroll vertical si el gesto es horizontal
      slider.addEventListener('touchmove', function (e) {
        if (swiped || isMoving) return;

        var diffX = touchStartX - e.touches[0].clientX;
        var diffY = touchStartY - e.touches[0].clientY;

        // Si el movimiento es más horizontal que vertical, bloquear scroll vertical
        if (Math.abs(diffX) > Math.abs(diffY)) {
          e.preventDefault();
        }
      }, { passive: false });

      // Al soltar, si el swipe fue suficientemente largo, cambiar de slide
      slider.addEventListener('touchend', function (e) {
        if (swiped || isMoving) return;

        var touchEndX = e.changedTouches[0].clientX;
        var diff = touchStartX - touchEndX; // positivo = swipe izquierda (siguiente)

        var minSwipe = 50; // píxeles mínimos para considerar swipe

        if (Math.abs(diff) < minSwipe) return; // demasiado corto, ignorar

        var atEnd   = currentIndex === maxIndex;
        var atStart = currentIndex === 0;

        // Swipe izquierda (siguiente) bloqueado si estamos al final
        if (diff > 0 && atEnd) return;
        // Swipe derecha (anterior) bloqueado si estamos al inicio
        if (diff < 0 && atStart) return;

        swiped = true; // marcar que ya procesamos este gesto
        goTo(currentIndex + (diff > 0 ? 1 : -1));
      }, { passive: true });

      // Posición inicial del track
      track.style.transform = 'translateX(0%)';

      // Estado inicial de flechas
      updateArrows();

      // Flechas clickeables para navegar
      if (arrowLeft) {
        arrowLeft.addEventListener('click', function () {
          if (currentIndex > 0 && !isMoving) goTo(currentIndex - 1);
        });
      }
      if (arrowRight) {
        arrowRight.addEventListener('click', function () {
          if (currentIndex < maxIndex && !isMoving) goTo(currentIndex + 1);
        });
      }
    })();
    </script>
  </body>
</html>

